 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# CAT-DRL: Full Experiment Pipeline\n",
    "### Mehrabi & Morphew — Purdue University, 2026\n",
    "---\n",
    "This notebook runs the full 25-condition experiment described in the paper.\n",
    "All code lives in the six Python modules; this notebook just wires them together.\n",
    "\n",
    "**Module map:**\n",
    "- `A_item_bank.py`  — Bank generation (synthetic × 2 + ASSISTments)\n",
    "- `B_irt_core.py`   — 3PL, FI, Hybrid MLE, WLE (shared math)\n",
    "- `C_baselines.py`  — MFI, KL-L, a-Strat, Random, MFI+WLE\n",
    "- `D_dqn_agents.py` — DQN-MSE, DQN-Huber, DQN-Huber+POCAR\n",
    "- `E_simulation.py` — Unified CAT runner (same engine for all methods)\n",
    "- `F_analysis.py`   — Metrics, Lorenz curves, all figures, LaTeX tables\n",
    "- `run_all.py`      — Orchestrator: runs everything end-to-end\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Step 0: Mount Drive & install dependencies"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "# Copy module files to working directory\n",
    "import shutil, os\n",
    "MODULE_DIR = '/content/drive/MyDrive/CAT_agent/cat_research/'\n",
    "os.makedirs(MODULE_DIR, exist_ok=True)\n",
    "\n",
    "# All 6 modules should be in MODULE_DIR\n",
    "# If running for the first time, upload them from your local machine\n",
    "print('Working directory:', MODULE_DIR)\n",
    "print('Files present:', os.listdir(MODULE_DIR))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, MODULE_DIR)\n",
    "\n",
    "# Verify all modules load\n",
    "import A_item_bank, B_irt_core, C_baselines, D_dqn_agents, E_simulation, F_analysis\n",
    "print('All modules loaded successfully.')\n",
    "\n",
    "import numpy as np, pandas as pd, torch\n",
    "print(f'PyTorch: {torch.__version__}  |  GPU: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else \"CPU\"}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Step 1: Unit tests — verify math is correct before running anything"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run IRT core unit tests\n",
    "# All 8 tests should pass before proceeding\n",
    "B_irt_core._run_tests()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run baseline selector mini-validation (N=100, T=40)\n",
    "# Expected: Random RMSE > MFI RMSE, MFI Gini >> Random Gini\n",
    "import subprocess\n",
    "subprocess.run([sys.executable, MODULE_DIR + 'C_baselines.py'], check=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Step 2: Build item banks"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from A_item_bank import generate_bank_uncorrelated, generate_bank_correlated, sample_theta\n",
    "\n",
    "OUTPUT_DIR = '/content/drive/MyDrive/CAT_agent/results/'\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "# Build and inspect both synthetic banks\n",
    "bank_uncor_df = generate_bank_uncorrelated(n=500, seed=42)\n",
    "bank_cor_df   = generate_bank_correlated(n=500, ab_corr=0.30, seed=42)\n",
    "\n",
    "# Save to Drive\n",
    "bank_uncor_df.to_csv(OUTPUT_DIR + 'bank_uncor.csv', index=True)\n",
    "bank_cor_df.to_csv(OUTPUT_DIR + 'bank_cor.csv', index=True)\n",
    "\n",
    "bank_uncor = bank_uncor_df[['a','b','c']].values\n",
    "bank_cor   = bank_cor_df[['a','b','c']].values\n",
    "\n",
    "print('\\nUncorrelated bank:')\n",
    "print(bank_uncor_df.describe().round(3))\n",
    "print('\\nCorrelated bank:')\n",
    "print(bank_cor_df.describe().round(3))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 3 (optional): ASSISTments real-data bank\n",
    "Skip this cell if you don't have the ASSISTments 2009 CSV.\n",
    "The CSV can be downloaded from: https://sites.google.com/site/assistmentsdata/home/assistment-2009-2010-data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from A_item_bank import calibrate_assistments_bank\n",
    "\n",
    "ASSIST_CSV = '/content/drive/MyDrive/CAT_agent/data/assistments_2009.csv'\n",
    "ASSIST_BANK_PATH = OUTPUT_DIR + 'bank_assistments.csv'\n",
    "\n",
    "if os.path.exists(ASSIST_BANK_PATH):\n",
    "    print('Loading pre-calibrated ASSISTments bank...')\n",
    "    from A_item_bank import load_pretrained_bank\n",
    "    bank_assist_df = load_pretrained_bank(ASSIST_BANK_PATH)\n",
    "elif os.path.exists(ASSIST_CSV):\n",
    "    print('Calibrating ASSISTments bank (may take 5-10 min)...')\n",
    "    bank_assist_df = calibrate_assistments_bank(ASSIST_CSV, n_items_target=500)\n",
    "    bank_assist_df.to_csv(ASSIST_BANK_PATH, index=True)\n",
    "    print(f'Saved → {ASSIST_BANK_PATH}')\n",
    "else:\n",
    "    print(f'ASSISTments CSV not found at {ASSIST_CSV}')\n",
    "    print('Proceeding with synthetic banks only.')\n",
    "    bank_assist_df = None\n",
    "\n",
    "bank_assist = bank_assist_df[['a','b','c']].values if bank_assist_df is not None else None"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Step 4: Generate fixed test set (same for ALL conditions)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from E_simulation import make_test_set\n",
    "\n",
    "theta_test = make_test_set(n=5000, distribution='normal', seed=99)\n",
    "np.save(OUTPUT_DIR + 'theta_test.npy', theta_test)\n",
    "\n",
    "print(f'Test set: N={len(theta_test)}')\n",
    "print(f'  mean={theta_test.mean():.4f}  std={theta_test.std():.4f}')\n",
    "print(f'  min={theta_test.min():.3f}   max={theta_test.max():.3f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Step 5: Run classical baselines (all banks, both priors)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from C_baselines import make_selector\n",
    "from E_simulation import run_condition\n",
    "\n",
    "BANKS    = {'uncor': bank_uncor, 'cor': bank_cor}\n",
    "if bank_assist is not None:\n",
    "    BANKS['assistments'] = bank_assist\n",
    "\n",
    "CLASSICAL = ['random', 'mfi', 'mfi+wle', 'kl-l', 'a-strat']\n",
    "PRIORS    = ['normal', 'uniform']\n",
    "\n",
    "baseline_results = {}\n",
    "for bank_name, bank in BANKS.items():\n",
    "    priors = PRIORS if bank_name != 'assistments' else ['normal']\n",
    "    for prior in priors:\n",
    "        for method_str in CLASSICAL:\n",
    "            cname    = f\"{bank_name}_{prior}_{method_str.replace('+','plus')}\"\n",
    "            selector = make_selector(method_str, bank, test_length=40)\n",
    "            df = run_condition(selector, bank, theta_test, cname,\n",
    "                               output_dir=OUTPUT_DIR, test_length=40)\n",
    "            baseline_results[cname] = df\n",
    "\n",
    "print(f'\\nBaselines complete: {len(baseline_results)} conditions')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 6: Train and evaluate DQN agents\n",
    "**Estimated time: ~15 min per agent × 2 priors × 2 banks = ~2 hours**\n",
    "Checkpoints are saved after each agent — restart safely."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from D_dqn_agents import make_dqn_agent\n",
    "\n",
    "CKPT_DIR = OUTPUT_DIR + 'checkpoints/'\n",
    "os.makedirs(CKPT_DIR, exist_ok=True)\n",
    "\n",
    "DQN_METHODS  = ['dqn-mse', 'dqn-huber', 'dqn-huber+pocar']\n",
    "val_histories = {}\n",
    "dqn_results   = {}\n",
    "\n",
    "for bank_name, bank in BANKS.items():\n",
    "    priors = PRIORS if bank_name != 'assistments' else ['normal']\n",
    "    for prior in priors:\n",
    "        theta_train = sample_theta(1000, prior, seed=42 + 1)\n",
    "\n",
    "        for method_str in DQN_METHODS:\n",
    "            cname     = f\"{bank_name}_{prior}_{method_str.replace('+','plus')}\"\n",
    "            ckpt_path = CKPT_DIR + f'{cname}.pt'\n",
    "            agent     = make_dqn_agent(method_str, n_items=500)\n",
    "\n",
    "            if os.path.exists(ckpt_path):\n",
    "                print(f'Loading {cname} ...')\n",
    "                agent.load(ckpt_path)\n",
    "            else:\n",
    "                print(f'Training {cname} ...')\n",
    "                train_result = agent.train(\n",
    "                    item_bank=bank, theta_train=theta_train,\n",
    "                    training_size=1000, test_length=40,\n",
    "                    validation_size=200, validation_interval=50,\n",
    "                    prior=prior, verbose=True\n",
    "                )\n",
    "                agent.save(ckpt_path)\n",
    "                val_histories[f'{cname}'] = train_result['validation_history']\n",
    "\n",
    "            df = run_condition(agent, bank, theta_test, cname,\n",
    "                               output_dir=OUTPUT_DIR, test_length=40)\n",
    "            dqn_results[cname] = df\n",
    "\n",
    "print(f'DQN experiments complete: {len(dqn_results)} conditions')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Step 7: Run full analysis and produce all figures"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from F_analysis import run_full_analysis\n",
    "\n",
    "outputs = run_full_analysis(\n",
    "    results_dir=OUTPUT_DIR,\n",
    "    output_dir=OUTPUT_DIR + 'figures/',\n",
    "    n_items=500\n",
    ")\n",
    "print('\\nAnalysis complete. Figures saved to', OUTPUT_DIR + 'figures/')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Step 8: Display key figures inline"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from IPython.display import Image, display\n",
    "import glob\n",
    "\n",
    "fig_dir = OUTPUT_DIR + 'figures/'\n",
    "for fig_path in sorted(glob.glob(fig_dir + '*.png')):\n",
    "    print(f'\\n--- {os.path.basename(fig_path)} ---')\n",
    "    display(Image(filename=fig_path, width=900))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 9: Quick sanity check on your existing data\n",
    "Load the CSVs you already have and verify they match the expected numbers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load your existing CSVs and check key statistics\n",
    "from F_analysis import step_metrics, exposure_stats, gini\n",
    "\n",
    "existing_csvs = {\n",
    "    'DQN-Huber (normal prior)':  '/content/drive/MyDrive/CAT_agent/records_uncor_1_DQN_normal_gamma_0.1.csv',\n",
    "    'DQN-Huber (uniform prior)': '/content/drive/MyDrive/CAT_agent/records_uncor_1_DQN_uniform_gamma_0.1.csv',\n",
    "}\n",
    "\n",
    "for label, path in existing_csvs.items():\n",
    "    if os.path.exists(path):\n",
    "        df = pd.read_csv(path)\n",
    "        sm = step_metrics(df, label)\n",
    "        final = sm[sm['step'] == sm['step'].max()].iloc[0]\n",
    "        stats, series = exposure_stats(df, label)\n",
    "        print(f'\\n{label}')\n",
    "        print(f'  Final step: RMSE={final[\"RMSE\"]:.4f}  Bias={final[\"Bias\"]:+.4f}  MAE={final[\"MAE\"]:.4f}')\n",
    "        print(f'  Items used: {stats[\"items_used\"]}/500  ({stats[\"items_used_pct\"]}%)')\n",
    "        print(f'  Gini coeff: {stats[\"gini\"]:.4f}  (0=uniform, 1=concentrated)')\n",
    "        print(f'  Max exposure: {stats[\"max_exposure\"]:.4f}')\n",
    "    else:\n",
    "        print(f'{label}: not found at {path}')"
   ]
  }
 ]
}"
